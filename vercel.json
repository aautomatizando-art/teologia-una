{
  "version": 2,
  "routes": [
    { "src": "/encoder", "dest": "/esp32-encoder-dashboard.html" },
    { "src": "/encoder/", "dest": "/esp32-encoder-dashboard.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
