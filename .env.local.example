# ===== SUPABASE (obrigatório) =====
# Crie um projeto em https://supabase.com e copie em Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ===== SESSÃO (obrigatório) =====
# Qualquer texto longo e aleatório
AUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio

# ===== WHATSAPP (opcional - escolha UM provedor) =====
# Provedor: "evolution" (recomendado p/ grupos) ou "callmebot"
WHATSAPP_PROVIDER=

# --- Evolution API (https://doc.evolution-api.com) ---
EVOLUTION_URL=
EVOLUTION_INSTANCE=
EVOLUTION_APIKEY=
# JID do grupo, ex: 120363045678901234@g.us
EVOLUTION_GROUP_JID=

# --- CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/) ---
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
